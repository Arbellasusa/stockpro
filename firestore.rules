rules_version = '2';
// ═══════════════════════════════════════════════════════════════════════════
//  STOCKPRO v2 — FIRESTORE SECURITY RULES
//  Hotel Arbellas · Plantation, FL
//  Project: hk-pro-housekeeping
//
//  ARCHITECTURE:
//  - Anonymous users:     READ NOTHING, WRITE NOTHING
//  - Authenticated users: READ by role, WRITE only own scope
//  - Admins:              Full read/write with audit trail
//  - No client can delete audit logs or override server timestamps
// ═══════════════════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // ── HELPER FUNCTIONS ─────────────────────────────────────────────────

    // Must be authenticated
    function isAuth() {
      return request.auth != null && request.auth.uid != null;
    }

    // Emails allowed to bootstrap themselves as administrator. Keep in sync with index.html.
    function isBootstrapAdminEmail() {
      return isAuth() && request.auth.token.email in [
        'roldanarbella97@gmail.com',
        'roldanarbella79@myyahoo.com'
      ];
    }

    function validOwnProfileCreate(userId) {
      return isAuth()
        && request.auth.uid == userId
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 120
        && request.resource.data.createdAt == request.time
        && request.resource.data.lastSeen == request.time
        && request.resource.data.online is bool
        && request.resource.data.createdBy in ['bootstrap_admin_email','self_register','first_admin_setup']
        && (
          (isBootstrapAdminEmail() && request.resource.data.role == 'administrator') ||
          (!isBootstrapAdminEmail() && request.resource.data.role == 'housekeeping')
        );
    }

    // Read role from Firestore user profile (set by admin on creation)
    function userRole() {
      return get(/databases/$(database)/documents/stockpro_usuarios/$(request.auth.uid)).data.role;
    }

    // Role checks
    function isAdmin()     { return isAuth() && userRole() == 'administrator'; }
    function isManager()   { return isAuth() && userRole() == 'warehouse_manager'; }
    function isSupervisor(){ return isAuth() && userRole() == 'supervisor'; }
    function isHK()        { return isAuth() && userRole() == 'housekeeping'; }

    // Any authorized staff (all roles)
    function isStaff() {
      return isAuth() && userRole() in ['administrator','warehouse_manager','supervisor','housekeeping'];
    }

    // Can write inventory (admin + warehouse manager only)
    function canWriteInventory() {
      return isAuth() && userRole() in ['administrator','warehouse_manager'];
    }

    // Can register movements (admin + warehouse manager + supervisor)
    function canWriteMovements() {
      return isAuth() && userRole() in ['administrator','warehouse_manager','supervisor'];
    }

    // Enforce server timestamp on write — prevents client time manipulation
    function hasServerTimestamp(field) {
      return request.resource.data[field] == request.time;
    }

    // Enforce immutable audit fields — can't be changed after creation
    function auditFieldsUnchanged() {
      return !request.resource.data.diff(resource.data).affectedKeys()
               .hasAny(['createdAt','createdBy','_audit']);
    }

    // Validate string is non-empty and under max length
    function validStr(field, maxLen) {
      return request.resource.data[field] is string &&
             request.resource.data[field].size() > 0 &&
             request.resource.data[field].size() <= maxLen;
    }

    // Validate positive number
    function validPositiveNum(field) {
      return request.resource.data[field] is number &&
             request.resource.data[field] >= 0;
    }

    // ── USER PROFILES ────────────────────────────────────────────────────
    match /stockpro_usuarios/{userId} {
      // A user can read their own profile. Staff can read all profiles.
      allow read: if isStaff() || (isAuth() && request.auth.uid == userId);

      // Secure self-bootstrap:
      // - Approved owner emails may create their own administrator profile.
      // - All other authenticated users may only create their own housekeeping profile.
      // - Admins may create staff profiles.
      allow create: if isAdmin() || validOwnProfileCreate(userId);

      // Users update only presence/name on their own profile. Admins can update roles/users.
      allow update: if isAdmin() || (
        isAuth() && request.auth.uid == userId
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['online','lastSeen','name'])
      );

      // Only admin can delete profiles
      allow delete: if isAdmin();
    }

    // ── INVENTORY ────────────────────────────────────────────────────────
    match /stockpro_inventario/{itemId} {
      // Any staff can read inventory
      allow read: if isStaff();

      // Only warehouse manager or admin can create items
      allow create: if canWriteInventory()
        && validStr('name', 200)
        && validStr('sku', 50)
        && validStr('barcode', 100)
        && validPositiveNum('qty')
        && validPositiveNum('price')
        && hasServerTimestamp('createdAt')
        && request.resource.data.createdBy == request.auth.uid;

      // Update: manager/admin can update; housekeeping CANNOT
      allow update: if canWriteInventory()
        && auditFieldsUnchanged()
        && validStr('name', 200)
        && validPositiveNum('qty')
        && validPositiveNum('price')
        && hasServerTimestamp('updatedAt')
        && request.resource.data.updatedBy == request.auth.uid;

      // Only admin can delete (soft-delete preferred)
      allow delete: if isAdmin();
    }

    // ── MOVEMENTS (APPEND-ONLY) ───────────────────────────────────────────
    match /stockpro_movimientos/{movId} {
      // Any staff can read movements
      allow read: if isStaff();

      // Any authorized staff can create movement records
      allow create: if canWriteMovements()
        && request.resource.data.type in ['ENTRADA','SALIDA','AJUSTE']
        && validStr('productName', 200)
        && validPositiveNum('qty')
        && request.resource.data.qty > 0
        && hasServerTimestamp('date')
        && request.resource.data.createdBy == request.auth.uid;

      // NO updates or deletes — movements are immutable audit records
      allow update: if false;
      allow delete: if false;
    }

    // ── DELIVERIES ────────────────────────────────────────────────────────
    match /stockpro_deliveries/{delId} {
      // Staff can read deliveries
      allow read: if isStaff();

      // Manager, supervisor, or admin can create deliveries
      allow create: if canWriteMovements()
        && validStr('roomNumber', 20)
        && hasServerTimestamp('date')
        && request.resource.data.createdBy == request.auth.uid;

      // No updates or deletes — deliveries are immutable records
      allow update: if false;
      allow delete: if false;
    }

    // ── AUDIT LOG (WRITE-ONCE) ────────────────────────────────────────────
    match /stockpro_audit/{logId} {
      // Only admin can read audit logs
      allow read: if isAdmin();

      // Any staff can create audit entries (append-only)
      allow create: if isStaff()
        && hasServerTimestamp('timestamp')
        && request.resource.data.uid == request.auth.uid;

      // Audit logs can NEVER be modified or deleted
      allow update: if false;
      allow delete: if false;
    }

    // ── BACKUPS ───────────────────────────────────────────────────────────
    match /stockpro_backups/{backupId} {
      // Only admin can read or create backups
      allow read, create: if isAdmin();
      allow update, delete: if false;
    }

    // ── DAILY SNAPSHOTS ───────────────────────────────────────────────────
    match /stockpro_snapshots/{snapId} {
      allow read: if isStaff();
      allow create: if canWriteInventory()
        && hasServerTimestamp('savedAt');
      allow update: if canWriteInventory()
        && auditFieldsUnchanged();
      allow delete: if false;
    }

    // ── SHARED WITH HK PRO ENTERPRISE ────────────────────────────────────
    match /solicitudes/{id}       { allow read, write: if isStaff(); }
    match /productosHydeHouse/{id}{ allow read: if isStaff(); allow write: if canWriteInventory(); }
    match /incidencias/{id}       { allow read, write: if isStaff(); }
    match /habitaciones/{id}      { allow read, write: if isStaff(); }
    match /mensajes/{id}          { allow read, write: if isStaff(); }
    match /usuarios/{id}          { allow read, write: if isStaff(); }

    // ── DEFAULT: DENY EVERYTHING ELSE ─────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
