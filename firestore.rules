rules_version = '2';
// ═══════════════════════════════════════════════════════════════
//  STOCKPRO v2 — FIRESTORE SECURITY RULES
//  Hotel Arbellas · Plantation, FL · Project: hk-pro-housekeeping
// ═══════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // ── HELPER FUNCTIONS ─────────────────────────────────────

    function isAuth() {
      return request.auth != null && request.auth.uid != null;
    }

    // Bootstrap admin emails — allowed to self-create/repair admin profile
    function isBootstrapEmail() {
      return isAuth() && request.auth.token.email in [
        'roldanarbella97@gmail.com',
        'roldanarbella79@myyahoo.com'
      ];
    }

    function isOwnDoc(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    // Role from Firestore profile (server-side, unforgeable)
    function userRole() {
      return get(/databases/$(database)/documents/stockpro_usuarios/$(request.auth.uid)).data.role;
    }

    function isAdmin()      { return isAuth() && userRole() == 'administrator'; }
    function isManager()    { return isAuth() && userRole() == 'warehouse_manager'; }
    function isSupervisor() { return isAuth() && userRole() == 'supervisor'; }
    function isHK()         { return isAuth() && userRole() == 'housekeeping'; }

    function isStaff() {
      return isAuth() && userRole() in ['administrator','warehouse_manager','supervisor','housekeeping'];
    }
    function canWriteInventory() {
      return isAuth() && userRole() in ['administrator','warehouse_manager'];
    }
    function canWriteMovements() {
      return isAuth() && userRole() in ['administrator','warehouse_manager','supervisor'];
    }

    function hasServerTimestamp(field) {
      return request.resource.data[field] == request.time;
    }
    function auditFieldsUnchanged() {
      return !request.resource.data.diff(resource.data).affectedKeys()
               .hasAny(['createdAt','createdBy','_audit']);
    }

    // ── USER PROFILES ────────────────────────────────────────
    match /stockpro_usuarios/{userId} {

      // KEY FIX: authenticated users can ALWAYS read their OWN profile document,
      // even when it doesn't exist yet (get() returns false on exists check).
      // This allows onAuthStateChanged to check profileDoc.exists safely.
      allow read: if isOwnDoc(userId) || isStaff();

      // New profile creation:
      //   - Bootstrap emails → can create as 'administrator'
      //   - Everyone else   → can only create as 'housekeeping'
      allow create: if isOwnDoc(userId)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email == request.auth.token.email
        && (
          request.resource.data.role == 'housekeeping'
          || (isBootstrapEmail() && request.resource.data.role == 'administrator')
        );

      // Profile updates:
      //   - Own presence/name only (online, lastSeen, name)
      //   - Bootstrap admin can also self-repair role → 'administrator'
      //   - Admin can update any profile
      allow update: if isOwnDoc(userId) && (
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['online','lastSeen','name'])
          ||
          (isBootstrapEmail()
            && request.resource.data.diff(resource.data).affectedKeys()
                 .hasOnly(['role','_roleFix'])
            && request.resource.data.role == 'administrator')
        )
        || isAdmin();

      allow delete: if isAdmin();
    }

    // ── INVENTORY ────────────────────────────────────────────
    match /stockpro_inventario/{itemId} {
      allow read: if isStaff();

      allow create: if canWriteInventory()
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.qty is number
        && request.resource.data.qty >= 0
        && hasServerTimestamp('createdAt')
        && request.resource.data.createdBy == request.auth.uid;

      allow update: if canWriteInventory()
        && auditFieldsUnchanged()
        && request.resource.data.qty is number
        && request.resource.data.qty >= 0
        && hasServerTimestamp('updatedAt')
        && request.resource.data.updatedBy == request.auth.uid;

      allow delete: if isAdmin();
    }

    // ── MOVEMENTS (append-only) ───────────────────────────────
    match /stockpro_movimientos/{movId} {
      allow read:   if isStaff();
      allow create: if canWriteMovements()
        && request.resource.data.type in ['ENTRADA','SALIDA','AJUSTE']
        && request.resource.data.qty is number
        && request.resource.data.qty > 0
        && hasServerTimestamp('date')
        && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if false;
    }

    // ── DELIVERIES ────────────────────────────────────────────
    match /stockpro_deliveries/{delId} {
      allow read:   if isStaff();
      allow create: if canWriteMovements()
        && request.resource.data.roomNumber is string
        && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if false;
    }

    // ── AUDIT LOG (write-once) ────────────────────────────────
    match /stockpro_audit/{logId} {
      allow read:   if isAdmin();
      allow create: if isStaff()
        && hasServerTimestamp('timestamp')
        && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    // ── BACKUPS ───────────────────────────────────────────────
    match /stockpro_backups/{backupId} {
      allow read, create: if isAdmin();
      allow update, delete: if false;
    }

    // ── SNAPSHOTS ─────────────────────────────────────────────
    match /stockpro_snapshots/{snapId} {
      allow read:   if isStaff();
      allow create: if canWriteInventory() && hasServerTimestamp('savedAt');
      allow update: if canWriteInventory() && auditFieldsUnchanged();
      allow delete: if false;
    }

    // ── DHS SUPPLIER ─────────────────────────────────────────
    match /stockpro_dhs_products/{id} {
      allow read:   if isStaff();
      allow create: if canWriteInventory()
        && request.resource.data.createdBy == request.auth.uid;
      allow update: if canWriteInventory();
      allow delete: if isAdmin();
    }
    match /stockpro_dhs_purchases/{id} {
      allow read:   if isStaff();
      allow create: if canWriteInventory()
        && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if false;
    }

    // ── SHARED (HK Pro Enterprise) ────────────────────────────
    match /solicitudes/{id}        { allow read, write: if isStaff(); }
    match /productosHydeHouse/{id} { allow read: if isStaff(); allow write: if canWriteInventory(); }
    match /incidencias/{id}        { allow read, write: if isStaff(); }
    match /habitaciones/{id}       { allow read, write: if isStaff(); }
    match /mensajes/{id}           { allow read, write: if isStaff(); }
    match /usuarios/{id}           { allow read, write: if isStaff(); }

    // ── DEFAULT: DENY ALL ─────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
